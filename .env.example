# Copy to .env.local and fill in your values.
# These are baked into the client bundle at build time (Vite VITE_ prefix).
# For dev, you can also configure these at runtime via the Settings panel in the UI.

VITE_TOKENHOUSE_URL=http://localhost:8787
VITE_TOKENHOUSE_KEY=th_your_key_here
VITE_TOKENHOUSE_MODEL=claude-sonnet-4-6
